# =============================================================================
# Traffic incident scraper — environment configuration
#
# Copy to .env on the EC2 host:
#   cp .env.example .env && chmod 600 .env
# The systemd unit loads this file via EnvironmentFile=.
# =============================================================================

# --- API keys ---
# TfNSW Open Data Hub — register free at https://opendata.transport.nsw.gov.au/
TFNSW_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiI5MlNYRk5QWVB3SFBPRTZ3UE9MLWJWVFJMY2lmdDU5SW9KeFVYdGwzMi0wIiwiaWF0IjoxNzc2NzMxNTE2fQ.JkO5nluT8kqGQFhQ4TSlzv4odt7LITH3WCOtOmMA0dA

# QLDTraffic — the published public key works out of the box (100 req/min GLOBAL).
# For production, email qldtraffic@tmr.qld.gov.au for your own key.
QLDTRAFFIC_API_KEY=3e83add325cbb69ac4d8e5bf433d770b

# DTP Victoria — sign up at https://opendata.transport.vic.gov.au/ and copy the
# primary key from your profile. Subscribe to the Unplanned Disruptions – Road
# product before using it.
DTPVIC_API_KEY=

# --- S3 destination ---
S3_BUCKET=datacruiser-stdb
S3_PREFIX=raw/traffic-incidents
S3_PROCESSED_PREFIX=processed/traffic-incidents
AWS_REGION=ap-southeast-2

# --- Runtime tuning ---
# HTTP timeout per request (seconds). Default 30.
HTTP_TIMEOUT=30
# Max retries on transient HTTP/network errors. Default 3.
HTTP_RETRIES=3
# Log level: DEBUG | INFO | WARNING | ERROR. Default INFO.
LOG_LEVEL=INFO
